# TaxNow GST Platform - Environment Variables

# Required
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/taxnow?retryWrites=true&w=majority
SECRET_KEY=your-super-secret-key-change-this-in-production

# Optional
DEBUG=false
PORT=8000
DATABASE_NAME=taxnow
DEFAULT_SUPPLIER_STATE=Maharashtra
HSN_VALIDATION=true
